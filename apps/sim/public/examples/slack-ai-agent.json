      "intent-router": {
        "id": "intent-router",
        "type": "agent",
        "name": "Intent Router",
        "position": { "x": 450, "y": 300 },
        "subBlocks": {
          "messages": {
            "id": "messages",
            "type": "messages-input",
            "value": [
              {
                "role": "system",
                "content": "You are an intent classifier for a Slack AI assistant. Analyze the user's request and return ONLY valid JSON.\n\nAvailable services:\n- jira: Issue tracking, project management, bug reports, sprint status\n- confluence: Documentation, wiki pages, knowledge base, guides\n- github: Code repositories, PRs, issues, branches, commits\n- slack: Channel history, user info, recent messages\n- general: General questions that don't require external data\n\nReturn exactly this JSON structure:\n{\"intent\": \"<one of: jira|confluence|github|slack|general>\", \"query\": \"<optimized search query for the service, empty string for general>\", \"reasoning\": \"<brief explanation under 30 words>\"}\n\nNote: Ignore the Slack mention prefix (e.g., <@U...>) in the user's message."
              },
              {
                "role": "user",
                "content": "<slack-trigger.event.text>"
              }
            ]
          },
          "model": {
            "id": "model",
            "type": "combobox",
            "value": "claude-haiku-4-5-20251001"
          },
          "temperature": {
            "id": "temperature",
            "type": "slider",
            "value": 0.3
          },
          "tools": {
            "id": "tools",
            "type": "tool-input",
            "value": []
          },
          "responseFormat": {
            "id": "responseFormat",
            "type": "code",
            "value": "{\n  \"name\": \"intent_classification\",\n  \"description\": \"Classify user intent and generate search query\",\n  \"strict\": true,\n  \"schema\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"intent\": {\n        \"type\": \"string\",\n        \"description\": \"The service to use for this request\",\n        \"enum\": [\"jira\", \"confluence\", \"github\", \"slack\", \"general\"]\n      },\n      \"query\": {\n        \"type\": \"string\",\n        \"description\": \"Optimized search query for the selected service, empty string for general\"\n      },\n      \"reasoning\": {\n        \"type\": \"string\",\n        \"description\": \"Brief explanation of the intent classification\"\n      }\n    },\n    \"additionalProperties\": false,\n    \"required\": [\"intent\", \"query\", \"reasoning\"]\n  }\n}"
          },
          "memoryType": {
            "id": "memoryType",
            "type": "dropdown",
            "value": "none"
          }
